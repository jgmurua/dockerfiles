{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "skill": {
      "*": "ask",
      "platform-engineer": "allow"
    },
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "bash": {
      "*": "ask",
      "kubectl get *": "allow",
      "kubectl describe *": "allow",
      "kubectl logs *": "allow",
      "kubectl top *": "allow",
      "helm list *": "allow",
      "helm status *": "allow",
      "helm get *": "allow",
      "helm template *": "allow",
      "terraform fmt *": "allow",
      "terraform validate *": "allow",
      "terraform plan *": "ask",
      "terraform apply *": "ask",
      "terraform destroy *": "deny",
      "kubectl delete namespace *": "deny",
      "kubectl delete pvc *": "deny",
      "rm -rf *": "deny"
    },
    "edit": "ask"
  }
}
